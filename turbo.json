{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".cache/**"]
        },
        "test": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "e2e": {
            "dependsOn": ["^build"],
            "cache": false,
            "passThroughEnv": [
                "INTENTIC_E2E",
                "CLOUDFLARE_API_TOKEN",
                "CLOUDFLARE_ZONE",
                "FORGEJO_ADMIN_PASSWORD",
                "KOMODO_ADMIN_PASSWORD",
                "KOMODO_WEBHOOK_SECRET"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "passThroughEnv": ["WORKSPACE_ROOT", "DEV_COMMAND", "DEV_PORT"]
        },
        "watch": {
            "cache": false,
            "persistent": true
        }
    },
    "remoteCache": {
        "enabled": false
    },
    "concurrency": "200%"
}
