{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  // Strict locking: every docker image is pinned to a tag + sha256 digest in _libs/state-resolver/src/images.ts.
  // Keep digests maintained so a pin is always immutable.
  pinDigests: true,
  customManagers: [
    {
      // Read each pin from the frozen IMAGES map. The `renovate:` hint comment above an entry supplies the
      // depName; the string literal supplies the current tag + digest. This keeps images.ts plain TypeScript
      // with no build-time generation.
      customType: "regex",
      managerFilePatterns: ["/_libs/state-resolver/src/images\\.ts$/"],
      matchStrings: [
        "renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)[\\s\\S]*?\"[^\"]*:(?<currentValue>[^\"@]+)@(?<currentDigest>sha256:[a-f0-9]+)\"",
      ],
    },
  ],
  packageRules: [
    {
      // The SigNoz quartet (server + collector + schema-migrator + clickhouse) is version-interdependent and
      // its bumps touch the hardcoded collector/cluster configs in signoz.ts — group them into one PR so a
      // reviewer sees and validates the whole stack move together.
      groupName: "signoz stack",
      matchPackageNames: [
        "signoz/signoz",
        "signoz/signoz-otel-collector",
        "signoz/signoz-schema-migrator",
        "clickhouse/clickhouse-server",
      ],
    },
    {
      // FerretDB and its documentdb-extended postgres are paired by tag; bump them together.
      groupName: "ferretdb",
      matchPackageNames: ["ghcr.io/ferretdb/ferretdb", "ghcr.io/ferretdb/postgres-documentdb"],
    },
    {
      groupName: "komodo",
      matchPackageNames: ["ghcr.io/moghtech/komodo-core", "ghcr.io/moghtech/komodo-periphery"],
    },
  ],
}
