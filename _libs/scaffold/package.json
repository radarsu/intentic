{
    "name": "@intentic/scaffold",
    "version": "0.0.0",
    "description": "Shared scaffold for an intentic workspace — the intent-repo skeleton + deploy.config managed-region render/parse, used by the CLI's `init` and the sandbox daemon",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/intentic.git",
        "directory": "_libs/scaffold"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": {
                "@intentic/src": "./src/index.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "@intentic/src": "./src/index.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --build --watch",
        "test": "vitest run"
    },
    "dependencies": {
        "@intentic/sandbox-contract": "workspace:*",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@intentic/tsconfig": "workspace:*",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
