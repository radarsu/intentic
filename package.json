{
    "name": "@intentic/root",
    "version": "0.0.0",
    "private": true,
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/intentic.git"
    },
    "scripts": {
        "dev": "WORKSPACE_ROOT=\"${WORKSPACE_ROOT:-$PWD/.cache/workspace}\" DEV_COMMAND=\"${DEV_COMMAND:-pnpm dev}\" DEV_PORT=\"${DEV_PORT:-5173}\" turbo run dev --filter './_apps/*'",
        "build": "turbo run build",
        "lint": "oxlint --deny-warnings",
        "lint:fix": "oxlint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "pnpm lint && pnpm format:check",
        "intentic": "tsc -b tsconfig.libs.json && node _apps/cli/dist/cli.js",
        "demo:up": "tsc -b tsconfig.libs.json && node _apps/cli/dist/demo.js up",
        "demo:down": "tsc -b tsconfig.libs.json && node _apps/cli/dist/demo.js down",
        "demo:clear": "tsc -b tsconfig.libs.json && node _apps/cli/dist/demo.js clear",
        "test": "turbo run test",
        "e2e": "turbo run e2e --ui=stream",
        "publish:images": "bash scripts/publish-images.sh",
        "diff:stat": "git diff HEAD --shortstat",
        "clear": "find . \\( -name 'node_modules' -or -name '.cache' -or -name 'dist' -or -name '.turbo' -or -name 'pnpm-lock.yaml' \\) -exec rm -rf '{}' +",
        "cache:clear": "find . \\( -name '.cache' -or -name 'dist' -or -name '.turbo' \\) -exec rm -rf '{}' +",
        "deps:up": "pnpm --recursive update --latest",
        "libs:watch": "nice -n 15 tsc --build --watch --preserveWatchOutput tsconfig.libs.json"
    },
    "devDependencies": {
        "@semantic-release/exec": "catalog:",
        "@semantic-release/github": "catalog:",
        "@types/node": "catalog:",
        "knip": "catalog:",
        "oxlint": "catalog:",
        "prettier": "catalog:",
        "semantic-release": "catalog:",
        "tslib": "catalog:",
        "turbo": "catalog:",
        "typescript": "catalog:"
    },
    "engines": {
        "node": "24.18.0",
        "pnpm": "11.9.0"
    },
    "packageManager": "pnpm@11.9.0"
}
