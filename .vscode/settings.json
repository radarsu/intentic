{
    // Editor and explorer.
    "editor.bracketPairColorization.enabled": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "explicit",
        "source.addMissingImports": "always",
        "source.sortImports": "always"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.detectIndentation": false,
    "editor.fontLigatures": true,
    "editor.formatOnSave": true,
    "editor.guides.bracketPairs": "active",
    "editor.insertSpaces": true,
    "editor.rulers": [150],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 150,
    "search.exclude": {
        "**/dist": true,
        "**/pnpm-lock.yaml": true,
        "tmp": true
    },
    "window.title": "${folderName}",
    "terminal.integrated.fontSize": 13,

    // File nesting.
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        // * Environment.
        ".env.local": ".env.local.template",

        // * Node.js
        "package.json": ".editorconfig, .gitignore, .npmrc, .oxlintrc.json, .prettierrc.json, .prettierignore, pnpm-workspace.yaml, pnpm-lock.yaml, *.md, tsconfig.json, tsconfig.*.json, turbo.json, LICENSE, vitest.config.ts, .releaserc.json",

        // * TypeScript
        "*.js": "$(capture).d.ts, $(capture).js.map, $(capture).d.ts.map"
    },

    // Consistency.
    "files.eol": "\n",
    "files.exclude": {
        "**/.cache": true,
        "**/.turbo": true
    },

    // Git. Releases force-move the `stable` tag (.releaserc.json), so local tags must be replaceable on pull.
    "git.ignoreLimitWarning": true,
    "git.inputValidationSubjectLength": 128,
    "git.replaceTagsWhenPull": true,

    // JavaScript.
    "js/ts.suggestionActions.enabled": false,

    // TypeScript.
    "js/ts.preferences.importModuleSpecifier": "relative",
    "js/ts.preferences.includePackageJsonAutoImports": "on",
    "js/ts.preferences.quoteStyle": "double",
    "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
        "^(assert|console|constants|crypto|events|inspector|process|stream|url|v8|vm)$",
        "^(dns|fs|inspector)(\/promises)?$",
        "^node:(console|crypto|dns|fs|inspector)$",
        "^node:(inspector)(\/promises)?$",
        "^path(\/posix|\/win32)?$"
    ],
    "js/ts.preferences.preferTypeOnlyAutoImports": true,

    // TitleBar with different color per repository.
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#1e3a8a",
        "titleBar.inactiveBackground": "#000000"
    },
    "workbench.tree.enableStickyScroll": false,

    // Code spell checking.
    "cSpell.diagnosticLevel": "Hint",

    // Type-specific.
    "[dotenv]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "[ignore]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "[yaml]": {
        "editor.tabSize": 4
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}
