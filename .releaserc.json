{
    "branches": ["main"],
    "tagFormat": "v${version}",
    "plugins": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",
        [
            "@semantic-release/exec",
            {
                "prepareCmd": "pnpm --dir _libs/core version ${nextRelease.version} --no-git-tag-version --no-git-checks --allow-same-version && pnpm turbo run build --filter=@puristic/deploy",
                "publishCmd": "pnpm --dir _libs/core publish --access public --no-git-checks"
            }
        ],
        ["@semantic-release/github", { "successComment": false, "failComment": false }]
    ]
}
