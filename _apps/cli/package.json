{
    "name": "@intentic/cli",
    "version": "0.0.0",
    "description": "",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/radarsu/intentic.git",
        "directory": "_apps/cli"
    },
    "files": [
        "dist"
    ],
    "bin": {
        "intentic": "./dist/cli.js"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": {
                "@intentic/src": "./src/index.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "@intentic/src": "./src/index.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc --build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "e2e": "INTENTIC_E2E=1 vitest run cli.e2e"
    },
    "dependencies": {
        "@intentic/engine": "workspace:*",
        "@intentic/graph": "workspace:*",
        "@intentic/need-resolver": "workspace:*",
        "@intentic/providers": "workspace:*",
        "@intentic/state-resolver": "workspace:*",
        "@stricli/core": "^1.2.8",
        "tslib": "catalog:"
    },
    "devDependencies": {
        "@intentic/sdk": "workspace:*",
        "@intentic/tsconfig": "workspace:*",
        "@types/node": "catalog:",
        "@types/ssh2": "1.15.5",
        "ssh2": "1.17.0",
        "testcontainers": "^11.0.0",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
